# ══════════════════════════════════════════════════════════════════════════════
# NMC — Monte Carlo Simulation Project
# .gitignore
# ══════════════════════════════════════════════════════════════════════════════


# ══════════════════════════════════════════════════════════════════════════════
# Simulation outputs  (regenerated by running the exe)
# ══════════════════════════════════════════════════════════════════════════════
photons_data_*.csv
rd_data_*.csv
metrics_*.csv
*_H.mci
config file *.txt


# ══════════════════════════════════════════════════════════════════════════════
# Build artefacts  (Xcode)
# ═════════════════════════════════���════════════════════════════════════════════
NMC/Build/
*.o
*.d
*.dia
*.LinkFileList
*.hmap
*.ipa
*.dSYM/
*.app
DerivedData/
xcuserdata/
*.xccheckout
*.xcscmblueprint
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3


# ══════════════════════════════════════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/


# ══════════════════════════════════════════════════════════════════════════════
# Jupyter
# ══════════════════════════════════════════════════════════════════════════════
# Keep .ipynb files but strip checkpoint artefacts
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Uncomment if you want to strip notebook outputs before committing
# (recommended — keeps diffs clean; use `nbstripout` instead for automation)
# *.ipynb


# ══════════════════════════════════════════════════════════════════════════════
# Virtual environments
# ══════════════════════════════════════════════════════════════════════════════
.venv/
venv/
env/
ENV/
.env
.conda/
*.egg-info/
dist/
build/


# ══════════════════════════════════════════════════════════════════════════════
# Figures  (regenerated by notebooks)
# ══════════════════════════════════════════════════════════════════════════════
NMC-samples/figs/
# Keep the directory itself so the path exists on fresh clone
!NMC-samples/figs/.gitkeep


# ══════════════════════════════════════════════════════════════════════════════
# macOS
# ════════════════════════════��═════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?
*.icloud


# ══════════════════════════════════════════════════════════════════════════════
# VS Code / editors
# ══════════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~


# ══════════════════════════════════════════════════════════════════════════════
# Metal / GPU shader caches
# ══════════════════════════════════════════════════════════════════════════════
*.metallib
*.air
default.metallib

# ══════════════════════════════════════════════════════════════════════════════
# Xcode - User files
# ══════════════════════════════════════════════════════════════════════════════
xcuserdata/

**/*.xcodeproj/project.xcworkspace/*
!**/*.xcodeproj/project.xcworkspace/xcshareddata

**/*.xcodeproj/project.xcworkspace/xcshareddata/*
!**/*.xcodeproj/project.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings

**/*.playground/playground.xcworkspace/*
!**/*.playground/playground.xcworkspace/xcshareddata

**/*.playground/playground.xcworkspace/xcshareddata/*
!**/*.playground/playground.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings
